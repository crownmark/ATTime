@layout WindowLayoutLayout
@page "/my-calendar"

@attribute [Authorize]

<PageTitle>My Calendar</PageTitle>
<RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="" AlignItems="Radzen.AlignItems.Center" JustifyContent="Radzen.JustifyContent.SpaceBetween" Wrap="Radzen.FlexWrap.Wrap">
    <RadzenText Text="@($"{resource.FullName} Calendar")" TextStyle="TextStyle.H3" TagName="TagName.H1" />

    <RadzenStack Orientation="Radzen.Orientation.Horizontal" JustifyContent="Radzen.JustifyContent.Start" AlignItems="Radzen.AlignItems.Center" Gap="5">
        <RadzenButton Icon="refresh" ButtonStyle="Radzen.ButtonStyle.Success" Variant="Radzen.Variant.Outlined" Shade="Radzen.Shade.Light" Size="Radzen.ButtonSize.Small" Style="width: 28px; height: 28px" Click="@RefreshCalendarDataButton0Click"></RadzenButton>
        <RadzenLabel Text="Number of days to view (Multi-Day View):" />
        <RadzenSlider @bind-Value=@sliderNumberOfDays TValue="int" Min="1" Max="30" Style="margin-left:1.5rem;margin-right:1.5rem;" Change="NumberOfDaysChange" />
        <RadzenLabel Text="@($"{sliderNumberOfDays}")" />
    </RadzenStack>
</RadzenStack>

<RadzenStack Orientation="Radzen.Orientation.Horizontal" Visible="@(resources.Any())" JustifyContent="Radzen.JustifyContent.Center" AlignItems="Radzen.AlignItems.Center">
    
    @foreach(var item in resources.Where(x => x.IsActive == true && x.LicenseType == 1))
    {
        <RadzenButton ButtonStyle="Radzen.ButtonStyle.Secondary" Variant="Radzen.Variant.Outlined" Shade="Radzen.Shade.Light" Size="Radzen.ButtonSize.Small" Style="width: 100px; height: 100px" >
            <ChildContent>
                <RadzenStack Gap="5" AlignItems="Radzen.AlignItems.Center" JustifyContent="Radzen.JustifyContent.Center">
                    <RadzenImage Path="@($"images/{item.Id}.png")" class="avatar"></RadzenImage>
                    <RadzenLabel Text="@item.FullName" />
                </RadzenStack>
            </ChildContent>
            
        </RadzenButton>
    }
    
</RadzenStack>

<RadzenScheduler @ref="@scheduler0" TItem="Server.Models.CalendarEvent" Data="@calendarEvents" StartProperty="Start" EndProperty="End" TextProperty="Title" style="height: 84vh" SelectedIndex="1" AppointmentMove="@Scheduler0AppointmentMove" SlotRender="@Scheduler0SlotRender" SlotSelect="@Scheduler0SlotSelect" ContextMenu="@Scheduler0ContextMenu" AppointmentSelect="@Scheduler0AppointmentSelect" MoreSelect="@Scheduler0MoreSelect" DaySelect="@Scheduler0DaySelect" AppointmentRender="@Scheduler0AppointmentRender">
    <ChildContent>
        <RadzenDayView MinutesPerSlot="15" StartTime="@(new TimeSpan(6,0,0))">
            
        </RadzenDayView>
        <RadzenMultiDayView NumberOfDays="@sliderNumberOfDays" AdvanceDays="1" MinutesPerSlot="15" StartTime="@(new TimeSpan(6, 0, 0))" />
        <RadzenWeekView MinutesPerSlot="15" StartTime="@(new TimeSpan(6,0,0))"></RadzenWeekView>
        <RadzenMonthView />
        
    </ChildContent>
    <Template Context="calendarEvent">
        <RadzenStack Gap="5">
            <RadzenStack Orientation="Orientation.Horizontal" Gap="5">
                <RadzenIcon Icon="confirmation_number" Visible="@(calendarEvent.TicketId.HasValue)" />
                <RadzenIcon Icon="local_shipping" Visible="@((calendarEvent.ActionType.HasValue && calendarEvent.ActionType.Value == 29683374) || (calendarEvent.Status.HasValue && calendarEvent.Status.Value == 106))" />
                <RadzenIcon Icon="person" Visible="@((calendarEvent.ActionType.HasValue && calendarEvent.ActionType.Value == 29683373) || (calendarEvent.Status.HasValue && calendarEvent.Status.Value == 105))" />
                <RadzenText Text="@calendarEvent.Title"/>
            </RadzenStack>
            <RadzenText Text="@($"{calendarEvent.Start:t} - {calendarEvent.End:t}")" />
        </RadzenStack>
    </Template>
    
    
    
</RadzenScheduler>

<style>
.my-class {
    background-color: var(--rz-info-light);
}
.avatar {
    width: 50px;
    height: 50px;
    object-fit: scale-down;
    border-radius: 50%;
}
</style>

<script>
    window.scrollSchedulerToTime = function (isoDateString) {

        // Use passed-in date OR fallback to now
        const now = isoDateString ? new Date(isoDateString) : new Date();

        const currentMinutes = now.getHours() * 60 + now.getMinutes();

        const slots = document.querySelectorAll('.rz-slot-header');

        if (!slots || slots.length === 0) return;

        let closestSlot = null;
        let smallestDiff = Number.MAX_VALUE;

        slots.forEach(slot => {
            const text = slot.innerText.trim(); // "8 AM"

            const match = text.match(/(\d+)\s*(AM|PM)/i);
            if (!match) return;

            let hour = parseInt(match[1]);
            const period = match[2].toUpperCase();

            if (period === "PM" && hour !== 12) hour += 12;
            if (period === "AM" && hour === 12) hour = 0;

            const slotMinutes = hour * 60;

            const diff = Math.abs(currentMinutes - slotMinutes);

            if (diff < smallestDiff) {
                smallestDiff = diff;
                closestSlot = slot;
            }
        });

        if (closestSlot) {
            closestSlot.scrollIntoView({
                behavior: 'smooth',
                block: 'center'
            });
        }
    };
    
</script>
