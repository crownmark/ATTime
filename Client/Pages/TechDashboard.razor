<style>
    /* Keep window alive but hidden */
    .window.hidden-window {
        display: none !important;
    }

    /* Your centered window */
    .window {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 98%;
        max-width: 100%;
        max-height: 90vh;
        background: #1e1e1e;
        border: 1px solid #444;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        /* remove or keep low fallback */
        z-index: 1000;
    }

    .window-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        backdrop-filter: blur(2px); /* optional 🔥 */
        z-index: 1400;
        /* pointer-events: none; /* 👈 IMPORTANT: allows clicks through */ */

        transition: opacity 0.2s ease;
    }

    /* Header */
    .header {
        background: #2a2a2a;
        padding: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* Body scrolls */
    .body {
        padding: 12px;
        overflow-y: auto;
        flex: 1;
    }

    
    /* Taskbar */
    .taskbar {
        /* position: fixed; */
        bottom: 0;
        left: 0;
        right: 0;
        background: #1e1e1e;
        border-top: 1px solid #333;
        display: flex;
        flex-wrap: wrap;
        padding: 6px;
        gap: 6px;
        max-height: 120px;
        overflow-y: auto;
        z-index: 1500; /* 👈 BELOW windows */
    }

    .taskbar-item {
        background: #2d2d2d;
        color: #ddd;
        padding: 6px 12px;
        border-radius: 6px;
        cursor: pointer;
        white-space: nowrap;
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        .taskbar-item:hover {
            background: #3a3a3a;
        }
</style>

<script>
    window.scrollToTopBlazor = () => {
        const el = document.querySelector(".rz-body"); // adjust if needed
        if (el) {
            el.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    };
</script>