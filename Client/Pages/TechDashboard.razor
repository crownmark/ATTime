@page "/tech-dashboard"
@using CrownATTime.Client.CustomComponents.DialogManager
@using CrownATTime.Server.Models;

@attribute [Authorize]

<PageTitle>TechDashboard</PageTitle>




<RadzenRow AlignItems="Radzen.AlignItems.Center" Style="margin-bottom: 10px">
    <RadzenColumn SizeLG="6">
        <RadzenStack>
            
            <RadzenText Text="Tech Dashboard" TextStyle="TextStyle.H3" TagName="TagName.H1" />
            <RadzenText Text="Your single pane of glass for tickets, priorities, and the next 3 days of scheduling." TextStyle="Radzen.Blazor.TextStyle.Caption" TagName="Radzen.Blazor.TagName.Auto" />
        
        </RadzenStack>
    </RadzenColumn>
<RadzenColumn SizeLG="6">
    <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="Radzen.AlignItems.Normal" JustifyContent="Radzen.JustifyContent.End" Wrap="Radzen.FlexWrap.Wrap">
        <RadzenChip Text="Tech: Mark Williams" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined"></RadzenChip>
<RadzenChip Text="Status: Available" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined">
   
</RadzenChip>
<RadzenButton Text="New Ticket" Icon="add" Variant="Radzen.Variant.Filled" ButtonStyle="Radzen.ButtonStyle.Primary" Click="@NewTicketButtonClick"></RadzenButton>
    
    </RadzenStack>
    </RadzenColumn>
</RadzenRow>
<RadzenRow Style="margin-bottom: 10px" Visible="false">
    <RadzenColumn Size="12" SizeXS="6" SizeLG="3">
        <RadzenPanel>
            <HeaderTemplate>
                <RadzenStack Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                <RadzenText Text="All Open Tickets" TextStyle="Radzen.Blazor.TextStyle.H5" />
                </RadzenStack>
            </HeaderTemplate>
            <FooterTemplate>
                <RadzenStack Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                <RadzenText Text="All Queues" TextStyle="Radzen.Blazor.TextStyle.Body2" />
                </RadzenStack>
            </FooterTemplate>
            <ChildContent>
                <RadzenStack Style="width: 100%">
                    <RadzenText Text="25" TextAlign="Radzen.TextAlign.Center" Style="color: var(--rz-primary); font-weight: bold; margin-top: 10px; margin-bottom: 10px" TextStyle="Radzen.Blazor.TextStyle.H4" />
                </RadzenStack>
            </ChildContent>
        </RadzenPanel>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeXS="6" SizeLG="3">
    <RadzenPanel>
            <HeaderTemplate>
                <RadzenStack Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                <RadzenText Text="Scheduled Today" TextStyle="Radzen.Blazor.TextStyle.H5" />
                </RadzenStack>
            </HeaderTemplate>
            <FooterTemplate>
                <RadzenStack Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                <RadzenText Text="3 Onsite, 3 Remote, 2 Internal" TextStyle="Radzen.Blazor.TextStyle.Body2" />
                </RadzenStack>
            </FooterTemplate>
            <ChildContent>
                <RadzenStack Style="width: 100%">
                    <RadzenText Text="8" TextAlign="Radzen.TextAlign.Center" Style="color: var(--rz-success-dark); font-weight: bold; margin-top: 10px; margin-bottom: 10px" TextStyle="Radzen.Blazor.TextStyle.H4" />
                </RadzenStack>
            </ChildContent>
        </RadzenPanel>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeXS="6" SizeLG="3">
    <RadzenPanel>
            <HeaderTemplate>
                <RadzenStack Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                <RadzenText Text="New Tickets" TextStyle="Radzen.Blazor.TextStyle.H5" />
                </RadzenStack>
            </HeaderTemplate>
            <FooterTemplate>
                <RadzenStack Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                <RadzenText Text="Unworked or Newly Assigned" TextStyle="Radzen.Blazor.TextStyle.Body2" />
                </RadzenStack>
            </FooterTemplate>
            <ChildContent>
                <RadzenStack Style="width: 100%">
                    <RadzenText Text="2" TextAlign="Radzen.TextAlign.Center" Style="color: var(--rz-primary); font-weight: bold; margin-top: 10px; margin-bottom: 10px" TextStyle="Radzen.Blazor.TextStyle.H4" />
                </RadzenStack>
            </ChildContent>
        </RadzenPanel>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeXS="6" SizeLG="3">
    <RadzenPanel>
            <HeaderTemplate>
                <RadzenStack Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                <RadzenText Text="All Open Tickets" TextStyle="Radzen.Blazor.TextStyle.H5" />
                </RadzenStack>
            </HeaderTemplate>
            <FooterTemplate>
                <RadzenStack Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                <RadzenText Text="All Queues" TextStyle="Radzen.Blazor.TextStyle.Body2" />
                </RadzenStack>
            </FooterTemplate>
            <ChildContent>
                <RadzenStack Style="width: 100%">
                    <RadzenText Text="10" TextAlign="Radzen.TextAlign.Center" Style="color: var(--rz-warning); font-weight: bold; margin-top: 10px; margin-bottom: 10px" TextStyle="Radzen.Blazor.TextStyle.H4" />
                </RadzenStack>
            </ChildContent>
        </RadzenPanel>
    </RadzenColumn>
</RadzenRow>
<RadzenRow>
    <RadzenColumn Size="12" SizeSM="8" SizeMD="8">
        <RadzenPanel Style="margin-bottom: 10px" AllowCollapse="true">
            <HeaderTemplate>
                <RadzenRow AlignItems="Radzen.AlignItems.Center" Style="margin-bottom: 10px; width: 100%">
                    <RadzenColumn>
                        <RadzenStack>
                            <RadzenStack Orientation="Radzen.Orientation.Horizontal">
                                <RadzenIcon Icon="av_timer" />
                                <RadzenText Text="Open Time Entries" TextStyle="Radzen.Blazor.TextStyle.H5" TagName="TagName.H1" />
                                <RadzenButton Size="Radzen.ButtonSize.Small" ButtonStyle="Radzen.ButtonStyle.Success" Variant="Radzen.Variant.Outlined" Icon="refresh" Style="width: 40px" Click="@TimeEntriesGridRefreshButton1Click" MouseEnter="RefreshTimeEntriesButtonMouseEnter" MouseLeave="RefreshTimeEntriesButtonMouseLeave" Shade="Radzen.Shade.Light"></RadzenButton>

                            </RadzenStack>

                        </RadzenStack>
                    </RadzenColumn>

                </RadzenRow>
            </HeaderTemplate>
            <ChildContent>


                <RadzenDataGrid @ref="@myTimeEntriesGrid" TItem="@CrownATTime.Server.Models.ATTime.TimeEntry" Data="@timeEntries" RowSelect="@TimeEntryDataGrid0RowSelect" LoadData="@TimeEntriesDataGrid0LoadData" IsLoading="@myTimeEntriesGridLoading">
                    <Columns>
                        <RadzenDataGridColumn TItem="CrownATTime.Server.Models.ATTime.TimeEntry">
                            <Template>
                                <RadzenCard Style="width: 100%">
                                    <RadzenStack Style="width: 100%" Orientation="Radzen.Orientation.Horizontal" JustifyContent="Radzen.JustifyContent.SpaceBetween" Wrap="Radzen.FlexWrap.Wrap" AlignItems="Radzen.AlignItems.Center" Gap="2">
                                        <RadzenStack>
                                            <RadzenStack Style="width: 100%;white-space: break-spaces;" Gap="2">
                                                <RadzenText Text="@($"{context.TicketNumber} - {context.TicketTitle}")" TextStyle="Radzen.Blazor.TextStyle.Body1" Style="font-weight: bold" />
                                                <RadzenText Text="@context.AccountName" TextStyle="Radzen.Blazor.TextStyle.Caption" Style="color: var(--rz-base-200)" />

                                            </RadzenStack>
                                        </RadzenStack>
                                        <RadzenStack Orientation="Radzen.Orientation.Horizontal">
                                            <RadzenIcon Visible="@(context.TimeStampStatus)" Icon="pause" Style="color: var(--rz-danger)" />
                                            <RadzenIcon Visible="@(!context.TimeStampStatus)" Icon="play_arrow" IconColor="green" Style="color: var(--rz-success-dark)" />
                                            <RadzenText Text="@(TimeSpan.FromMilliseconds(context.DurationMs.Value).ToString(@"hh\:mm\:ss"))" Style="color: var(--rz-success-dark)" />
                                        </RadzenStack>
                                    </RadzenStack>
                                </RadzenCard>
                            </Template>
                            
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </ChildContent>
        </RadzenPanel>
        <RadzenPanel AllowCollapse="true">
            <HeaderTemplate>
                <RadzenRow AlignItems="Radzen.AlignItems.Center" Style="margin-bottom: 10px; width: 100%">
                    <RadzenColumn>
                        <RadzenStack>
                            <RadzenStack Orientation="Radzen.Orientation.Horizontal">
                                <RadzenIcon Icon="confirmation_number" />
                                <RadzenText Text="Tickets" TextStyle="Radzen.Blazor.TextStyle.H5" TagName="TagName.H1" />
                                <RadzenButton Size="Radzen.ButtonSize.Small" ButtonStyle="Radzen.ButtonStyle.Success" Variant="Radzen.Variant.Outlined" Icon="refresh" Click="@ReloadTicketsButton1Click" MouseEnter="RefreshTicketsButtonMouseEnter" MouseLeave="RefreshTicketsButtonMouseLeave" Shade="Radzen.Shade.Light"></RadzenButton>

                            </RadzenStack>

                        </RadzenStack>
                    </RadzenColumn>

                </RadzenRow>
            </HeaderTemplate>
            <ChildContent>
                <RadzenStack Style="width: 100%" Gap="10" Wrap="Radzen.FlexWrap.Wrap">
                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" Wrap="Radzen.FlexWrap.Wrap" Style="padding-top: 4px; padding-bottom: 4px; padding-right: 4px; padding-left: 4px; margin-bottom: 5px; min-height: 40px; max-height: 250px">
                        <RadzenChip Text="@($"Scheduled Today ({scheduledTodayTicketsCount})")" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined" Click="@ScheduledTodayChip3Click" Selected="@scheduledTodayTickets" Style="min-height: 40px">
                             <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="4" Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                                <RadzenLabel Text="Scheduled Today" />
                                <RadzenBadge Text="@scheduledTodayTicketsCount.ToString()" Variant="Radzen.Variant.Outlined" BadgeStyle="Radzen.BadgeStyle.Warning" IsPill="true"></RadzenBadge>
                            </RadzenStack>
                        </RadzenChip>
                        <RadzenChip Text="@($"Need To Schedule ({unscheduledTicketsCount})")" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined" Click="@UnScheduledTodayChip3Click" Selected="@unscheduledTickets" Style="min-height: 40px">
                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="4" Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                                <RadzenLabel Text="Need To Schedule" />
                                <RadzenBadge Text="@unscheduledTicketsCount.ToString()" Variant="Radzen.Variant.Outlined" BadgeStyle="Radzen.BadgeStyle.Warning" IsPill="true"></RadzenBadge>
                            </RadzenStack></RadzenChip>
                        <RadzenChip Text="@($"Overdue ({overdueTicketsCount})")" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined" Click="@OverdueChip6Click" Selected="@overdueTickets" Style="min-height: 40px">
                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="4" Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                                <RadzenLabel Text="Overdue" />
                                <RadzenBadge Text="@overdueTicketsCount.ToString()" Variant="Radzen.Variant.Outlined" BadgeStyle="Radzen.BadgeStyle.Warning" IsPill="true"></RadzenBadge>
                            </RadzenStack></RadzenChip>
                        <RadzenChip Text="@($"In My Court ({inMyCourtTicketsCount})")" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined" Selected="@inMyCourtTickets" Click="@InMyCourtChip3Click" Style="min-height: 40px">
                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="4" Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                                <RadzenLabel Text="In My Court" />
                                <RadzenBadge Text="@inMyCourtTicketsCount.ToString()" Variant="Radzen.Variant.Outlined" BadgeStyle="Radzen.BadgeStyle.Warning" IsPill="true"></RadzenBadge>
                            </RadzenStack>
                        </RadzenChip>
                        <RadzenChip Text="@($"New ({newTicketsCount})")" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined" Click="@NewTicketsChip4Click" Selected="@newTickets">
                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="4" Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                                <RadzenLabel Text="New" />
                                <RadzenBadge Text="@newTicketsCount.ToString()" Variant="Radzen.Variant.Outlined" BadgeStyle="Radzen.BadgeStyle.Warning" IsPill="true"></RadzenBadge>
                            </RadzenStack>
                        </RadzenChip>
                        <RadzenChip Text="@($"Waiting ({waitingTicketsCount})")" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined" Click="@WaitingTicketsChip5Click" Selected="@waitingTickets">
                            <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="4" Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                                <RadzenLabel Text="Waiting" />
                                <RadzenBadge Text="@waitingTicketsCount.ToString()" Variant="Radzen.Variant.Outlined" BadgeStyle="Radzen.BadgeStyle.Warning" IsPill="true"></RadzenBadge>
                            </RadzenStack>
                        </RadzenChip>
                        <RadzenChip Text="@($"All Open ({openTicketsCount})")" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined" Click="@AllOpenTicketsChip2Click" Selected="@openTickets" Style="min-height: 40px">
                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" Gap="4" Style="width: 100%" AlignItems="Radzen.AlignItems.Center">
                                <RadzenLabel Text="All Open" />
                                <RadzenBadge Text="@openTicketsCount.ToString()" Variant="Radzen.Variant.Outlined" BadgeStyle="Radzen.BadgeStyle.Warning" IsPill="true"></RadzenBadge>
                            </RadzenStack>
                        </RadzenChip>

                    </RadzenStack>
                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" JustifyContent="Radzen.JustifyContent.SpaceBetween" Style="width: 100%;  padding-bottom: 5px">
                        <RadzenTextBox Placeholder="Search Tickets..." Style="width: 50%" @bind-Value="@myTicketsSearch" @onkeydown:stopPropagation Change="@TicketSearchTextBox0Change"></RadzenTextBox>
                        <RadzenDropDown @bind-Value="@queueId" Placeholder="All Queues" Style="width: 50%" AllowClear="true" Data="@queues" ValueProperty="ValueInt" TextProperty="Label" Name="Queues" Change="@QueuesChange" ClearSearchAfterSelection="true" AllowFiltering="true" FilterCaseSensitivity="Radzen.FilterCaseSensitivity.CaseInsensitive"></RadzenDropDown>

                    </RadzenStack>

                </RadzenStack>
                <RadzenDataGrid @ref="@myTicketsGrid" IsLoading="@myTicketsGridLoading" TItem="TicketDtoResult.Item" Data="@myTickets" Responsive="true" AllowFiltering="false" FilterMode="Radzen.FilterMode.Advanced" AllowSorting="false" FilterCaseSensitivity="Radzen.FilterCaseSensitivity.CaseInsensitive" RowSelect="@TicketsDataGrid0RowSelect" LoadData="@TicketsDataGrid1LoadData">
                    
                    <Columns>
                        <RadzenDataGridColumn TItem="TicketDtoResult.Item" Title="Ticket" Width="450px" Property="title">
                            <Template>
                                <RadzenStack Style="width: 100%;white-space: break-spaces;" Gap="2">
                                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="Radzen.AlignItems.Center" Gap="5">
                                        <RadzenButton Icon="more_time" Variant="Radzen.Variant.Outlined" Size="Radzen.ButtonSize.Small" @onclick:stopPropagation Click="@((args) => AddTimeButton3Click(args, context))" Style="width: 28px; height: 28px" MouseEnter="@AddTimeEntryButtonMouseEnter" MouseLeave="@AddTimeEntryButtonMouseLeave"></RadzenButton>
                                        <RadzenText Text="@($"{context.ticketNumber} - {context.title}")" TextStyle="Radzen.Blazor.TextStyle.Body1">
                                        </RadzenText>
                                    </RadzenStack>

                                    <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="Radzen.AlignItems.Center" Gap="5">
                                        <RadzenText Text="@context.companyName" TextStyle="Radzen.Blazor.TextStyle.Caption" Style="color: var(--rz-primary)" />
                                        <RadzenText Text="@($"({context.queueName})")" TextStyle="Radzen.Blazor.TextStyle.Caption" Style="color: var(--rz-warning)" />

                                    </RadzenStack>

                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="TicketDtoResult.Item" Title="Priority" Property="priority" Width="125px">
                                                    <Template>
                                                        <RadzenBadge Text="@context.priorityName" BadgeStyle="Radzen.BadgeStyle.Warning" Variant="Radzen.Variant.Outlined" IsPill="true" Style="padding-left: 8px; padding-right: 9px; padding-top: 2px; padding-bottom: 2px"></RadzenBadge>
                                                    </Template>
                                                </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="TicketDtoResult.Item" Title="Status" Property="status" Width="200px">
                            <Template>
                                <RadzenStack AlignItems="Radzen.AlignItems.Start">
                                    <RadzenBadge Text="@context.statusName" Variant="Radzen.Variant.Outlined" IsPill="true" BadgeStyle="Radzen.BadgeStyle.Success" Style="padding-left: 8px; padding-right: 8px; padding-top: 2px; padding-bottom: 2px" Shade="Radzen.Shade.Dark"></RadzenBadge>
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="TicketDtoResult.Item" Title="Due" Property="OldestScheduledDate" Width="200px">
                            <Template>
                                <RadzenStack AlignItems="Radzen.AlignItems.Start">
                                    <RadzenText Text="@context.OldestScheduledDate?.ToLocalTime().ToString("MM-dd-yyyy h:mm tt")" />
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </ChildContent>
            
        </RadzenPanel>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeSM="4" SizeMD="4">
        <RadzenPanel Style="margin-bottom: 10px" AllowCollapse="true">
            <HeaderTemplate>
                <RadzenRow AlignItems="Radzen.AlignItems.Center" Style="margin-bottom: 10px; width: 100%">
                    <RadzenColumn >
                        <RadzenStack>
                            <RadzenStack Orientation="Radzen.Orientation.Horizontal">
                                <RadzenIcon Icon="av_timer" />
                                <RadzenText Text="Minimized Time Entries" TextStyle="Radzen.Blazor.TextStyle.H5" TagName="TagName.H1" />

                            </RadzenStack>

                        </RadzenStack>
                    </RadzenColumn>
                    
                </RadzenRow>
            </HeaderTemplate>

            <ChildContent>
                <RadzenPanel Style="margin-bottom: 10px; background-color: rgba(45, 48, 52, 0.51)" AllowCollapse="false">

                    <ChildContent>
                        <div id="desktop">
                            @foreach (var dialog in DialogManager.Dialogs)
                            {
                                @if (DialogManager.Dialogs.Any(d => !d.IsMinimized))
                                {
                                    var active = DialogManager.Dialogs
                                    .Where(d => !d.IsMinimized)
                                    .OrderByDescending(d => d.ZIndex)
                                    .FirstOrDefault();

                                    if (active != null)
                                    {
                                        <div class="window-overlay"
                                             style="z-index:@(active.ZIndex - 1)">
                                        </div>
                                    }
                                }
                                <div class="window @(dialog.IsMinimized ? "hidden-window" : "")"
                                     style="width:@dialog.Width; z-index:@dialog.ZIndex"
                                     @onclick="() => DialogManager.SetActive(dialog.Id, dialog.Type)">

                                    <div class="header">
                                        <span>@dialog.Title</span>

                                        <div>
                                            <RadzenButton @onclick:stopPropagation Click="@((args) => PopoutWindowButtonClick(args, dialog))" Variant="Radzen.Variant.Outlined" Size="Radzen.ButtonSize.ExtraSmall" Icon="open_in_browser" Style="width: 24px" MouseEnter="PopoutTimeEntryButtonMouseEnter" MouseLeave="PopoutTimeEntryButtonMouseLeave"/>
                                            <RadzenButton @onclick:stopPropagation Click="@((args) => MinimizeWindowButtonClick(args, dialog))" Variant="Radzen.Variant.Outlined" Size="Radzen.ButtonSize.ExtraSmall" Icon="minimize" Style="width: 24px" />
                                            <RadzenButton @onclick:stopPropagation Click="@((args) => CloseWindowButtonClick(args, dialog))" ButtonStyle="Radzen.ButtonStyle.Primary" Variant="Radzen.Variant.Outlined" Size="Radzen.ButtonSize.ExtraSmall" Icon="close" Style="width: 24px" />
                                            
                                        </div>
                                    </div>

                                    <div class="body">
                                        @dialog.Content
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Taskbar -->
                        <div class="taskbar">
                            @foreach (var dialog in DialogManager.Dialogs.Where(d => d.IsMinimized))
                            {
                                <div class="taskbar-item"
                                     title="@dialog.Title"
                                     @onclick="() => DialogManager.Restore(dialog.Id, dialog.Type)">
                                    @dialog.Title
                                </div>
                            }
                        </div>
                    </ChildContent>
                </RadzenPanel>
                
                
            </ChildContent>

        </RadzenPanel>
    <RadzenPanel Style="margin-bottom: 10px" AllowCollapse="true">
            <HeaderTemplate>
                <RadzenRow AlignItems="Radzen.AlignItems.Center" Style="margin-bottom: 10px; width: 100%">
                    <RadzenColumn SizeLG="8">
                        <RadzenStack>
                            <RadzenStack Orientation="Radzen.Orientation.Horizontal">
                            <RadzenIcon Icon="calendar_month" />
                            <RadzenText Text="Next 3 Days" TextStyle="Radzen.Blazor.TextStyle.H5" TagName="TagName.H1" />
                                <RadzenButton Size="Radzen.ButtonSize.Small" ButtonStyle="Radzen.ButtonStyle.Success" Variant="Radzen.Variant.Outlined" Icon="refresh" Style="width: 40px" Click="@CalendarGridRefreshButton1Click" MouseEnter="CalendarRefreshButtonMouseEnter" MouseLeave="CalendarRefreshButtonMouseLeave" Visible="true" IsBusy="@calendarGridLoading" Shade="Radzen.Shade.Light"></RadzenButton>

                            </RadzenStack>
                            <RadzenText Text="Calendar + scheduled ticket commitments" TextStyle="Radzen.Blazor.TextStyle.Caption" TagName="Radzen.Blazor.TagName.Auto" />
                        
                        </RadzenStack>
                    </RadzenColumn>
                    <RadzenColumn SizeLG="4">
                        <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="Radzen.AlignItems.Normal" JustifyContent="Radzen.JustifyContent.End">
                            <RadzenChip Text="Open Calendar" ChipStyle="Radzen.BadgeStyle.Primary" Variant="Radzen.Variant.Outlined" Click="@CalendarChip9Click"></RadzenChip>
    
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>
            </HeaderTemplate>
            
            <ChildContent>
                <RadzenPanel Style="margin-bottom: 10px; background-color: rgba(45, 48, 52, 0.51)" AllowCollapse="false">
                <HeaderTemplate>
                    <RadzenRow AlignItems="Radzen.AlignItems.Center" Style="margin-bottom: 10px; width: 100%">
                        <RadzenColumn Size="12">
                            <RadzenStack Orientation="Radzen.Orientation.Horizontal" JustifyContent="Radzen.JustifyContent.SpaceBetween">
                                <RadzenText Text="Today" TextStyle="Radzen.Blazor.TextStyle.H5" TagName="TagName.H1" />
                                    <RadzenText Text="@($"{DateTime.Today.ToString(" MMM d")}")" TextStyle="Radzen.Blazor.TextStyle.Body2" TagName="Radzen.Blazor.TagName.Auto" Style="color: var(--rz-primary)" />
                        
                            </RadzenStack>
                        </RadzenColumn>
                    
                    </RadzenRow>
                </HeaderTemplate>
            
                <ChildContent>
                        <RadzenDataGrid LoadData="CalendarDataGrid1LoadData" @ref="todaysEventsGrid" Responsive="true" TItem="Server.Models.CalendarEvent" Data="@(calendarEvents.Where(x => x.Start > DateTime.Today && x.Start <= DateTime.Today.AddDays(1)))" RowSelect="@TodayDataGrid1RowSelect" RowDeselect="@TodayDataGrid2RowDeselect" RowRender="@TodayDataGridRowRender" CellRender="@TodayDataGridCellRender" >
                        <Columns>
                                <RadzenDataGridColumn TItem="Server.Models.CalendarEvent">
                                <Template>
                                        <RadzenStack Style="@($"border-radius: 4px; width: 100%; padding:5px; {(context.EventType.Contains("Flexible") ? "background-color: var(--rz-primary-darker)" : context.EventType.Contains("Remote") ? "background-color: var(--rz-primary-darker)" : context.EventType.Contains("Onsite") ? "background-color: var(--rz-primary-darker)" : context.EventType.Contains("Service Call") ? "background-color: var(--rz-primary-darker)" : "")}")" Orientation="Radzen.Orientation.Horizontal">
                                            <RadzenStack>
                                                <RadzenLabel Text="@context.Start.ToLocalTime().ToString("h:mm tt")" Style="color: var(--rz-primary)" />
                                                <RadzenIcon Icon="confirmation_number" Visible="@(context.EventType.Contains("Flexible") || context.EventType.Contains("Remote") || context.EventType.Contains("Service Call"))" />
                                                <RadzenIcon Icon="local_shipping" Visible="@(context.EventType.Contains("Onsite"))" />
                                            </RadzenStack>
                                            <RadzenStack>
                                                <RadzenLabel Text="@($"{context.Title}")" style="white-space: break-spaces;" />
                                                <RadzenLabel Text="@($"{context.DurationFormatted} - {context.EventType} ")" />

                                            </RadzenStack>
                                        </RadzenStack>
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>

                
                </ChildContent>
            </RadzenPanel>
            <RadzenPanel Style="margin-bottom: 10px; background-color: rgba(45, 48, 52, 0.51)" AllowCollapse="false" Visible="false">
                <HeaderTemplate>
                    <RadzenRow AlignItems="Radzen.AlignItems.Center" Style="margin-bottom: 10px; width: 100%">
                        <RadzenColumn Size="12">
                            <RadzenStack Orientation="Radzen.Orientation.Horizontal" JustifyContent="Radzen.JustifyContent.SpaceBetween">
                                <RadzenText Text="Tomorrow" TextStyle="Radzen.Blazor.TextStyle.H5" TagName="TagName.H1" />
                                    <RadzenText Text="@($"{DateTime.Today.AddDays(1).ToString(" MMM d")}")" TextStyle="Radzen.Blazor.TextStyle.Body2" TagName="Radzen.Blazor.TagName.Auto" Style="color: var(--rz-primary)" />
                        
                            </RadzenStack>
                        </RadzenColumn>
                        </RadzenRow>
                </HeaderTemplate>
                <ChildContent>
